# -- NFSN Production Environment --------------------------------
# NOTE: On NFSN, hardcode these values directly in /home/protected/run.sh
# instead of using a .env file. The daemon cannot reliably access
# /home/private/.env due to user permission restrictions.
#
# This file exists only as a reference for what values are needed.

NODE_ENV=production
PORT=8080
CORS_ORIGIN=https://your-site.nfshost.com

# -- Database (MySQL / MariaDB on NFSN) -----------------------
DATABASE_URL="mysql://your_user:YOUR_ENCODED_PASSWORD@your-dsn.db:3306/your_database"

# -- Auth ------------------------------------------------------
JWT_SECRET="REPLACE-WITH-A-LONG-RANDOM-STRING"
