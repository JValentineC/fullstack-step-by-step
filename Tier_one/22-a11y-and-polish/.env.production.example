# Production env file used by `vite build` and `npm run deploy`.
# Vite automatically loads .env.production when building.

# Base path for GitHub Pages — must match your repo name with leading/trailing slashes.
VITE_BASE=/fullstack-step-by-step/

# Full URL of your deployed backend (no trailing slash).
# Leave blank for local dev (Vite proxy handles /api).
VITE_API_URL=https://your-backend.example.com
